# Knowledge service role credentials (override .env.database defaults)
# NOTE: Docker Compose env_file does NOT interpolate ${VAR} references — use literal values.
PG_DB_USER="cc_knowledge"
PG_DB_PASSWORD="!ChangeMe!!"
PG_DB_HOST="db"
PG_DB_PORT="5432"
PG_DB_NAME="codeclarity"
PG_DB_SSLMODE="verify-ca"
PG_DB_SSLROOTCERT="/var/lib/postgresql/certs/ca.crt"
